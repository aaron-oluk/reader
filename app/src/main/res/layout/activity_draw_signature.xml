<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light_gray">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_primary"
        android:paddingTop="52dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Draw Signature"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign using your finger or stylus"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Canvas card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/divider"
        app:cardBackgroundColor="@color/background_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Canvas label row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NEW SIGNATURE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.08" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Clear"
                    android:textSize="13sp"
                    android:textColor="@color/primary_blue"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Color picker -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ink Color"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <!-- Black -->
                <FrameLayout
                    android:id="@+id/color_black"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/color_dot_selected"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/circle_fill"
                        android:contentDescription="Black ink"
                        app:tint="#1C1C1E" />
                </FrameLayout>

                <!-- Dark Blue / Navy -->
                <FrameLayout
                    android:id="@+id/color_navy"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/color_dot_idle"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/circle_fill"
                        android:contentDescription="Navy ink"
                        app:tint="#1E1B4B" />
                </FrameLayout>

                <!-- Blue -->
                <FrameLayout
                    android:id="@+id/color_blue"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/color_dot_idle"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/circle_fill"
                        android:contentDescription="Blue ink"
                        app:tint="#2563EB" />
                </FrameLayout>

                <!-- Red -->
                <FrameLayout
                    android:id="@+id/color_red"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/color_dot_idle"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/circle_fill"
                        android:contentDescription="Red ink"
                        app:tint="#DC2626" />
                </FrameLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Signature drawing area -->
            <com.pdfreader.app.SignatureView
                android:id="@+id/signatureView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="240dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_margin="16dp"
                android:text="Save Signature"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_signature"
                app:iconTint="#FFFFFF"
                app:iconPadding="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
