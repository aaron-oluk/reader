<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light_gray">

    <!-- Gradient header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_primary"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign PDF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open a PDF then add your signature"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Save"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:enabled="false"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_save"
                app:iconTint="@color/primary_blue"
                app:iconPadding="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="visible">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="88dp"
                android:layout_height="88dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#EEF2FF"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_pdf"
                    app:tint="@color/primary_blue"
                    android:contentDescription="No document" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="No Document Selected"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Tap Open below to choose a PDF to sign"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectPdfEmpty"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:paddingHorizontal="32dp"
                android:text="Open PDF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- PDF pages -->
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/pagesRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />
        </ScrollView>
    </FrameLayout>

    <!-- Signature status bar — shown once signature is selected -->
    <LinearLayout
        android:id="@+id/statusInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="#EEF2FF"
        android:visibility="gone">

        <!-- Signature thumbnail -->
        <ImageView
            android:id="@+id/signaturePreviewImage"
            android:layout_width="64dp"
            android:layout_height="36dp"
            android:scaleType="centerInside"
            android:background="#FFFFFF"
            android:contentDescription="Selected signature" />

        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="10dp"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap a page to place signature"
            android:textSize="12sp"
            android:textColor="@color/primary_blue" />

        <!-- Compact ink color dots -->
        <FrameLayout
            android:id="@+id/sig_color_black"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/color_dot_selected"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/circle_fill"
                android:contentDescription="Black"
                app:tint="#1C1C1E" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/sig_color_navy"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/color_dot_idle"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/circle_fill"
                android:contentDescription="Navy"
                app:tint="#1E1B4B" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/sig_color_blue"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/color_dot_idle"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/circle_fill"
                android:contentDescription="Blue"
                app:tint="#2563EB" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/sig_color_red"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/color_dot_idle"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/circle_fill"
                android:contentDescription="Red"
                app:tint="#DC2626" />
        </FrameLayout>
    </LinearLayout>

    <!-- Invisible stub so Java's signaturePreviewCard reference doesn't crash -->
    <View
        android:id="@+id/signaturePreviewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Bottom tool palette -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="8dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="@color/background_white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- Open PDF -->
            <LinearLayout
                android:id="@+id/btnSelectPdf"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tool_open_icon_bg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#EEF2FF">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_pdf"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        app:tint="@color/primary_blue"
                        android:contentDescription="Open PDF" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Add Signature -->
            <LinearLayout
                android:id="@+id/btnAddSignature"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:alpha="0.4">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tool_sign_icon_bg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#EEF2FF">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_signature"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        app:tint="@color/primary_blue"
                        android:contentDescription="Add Signature" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
