<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light_gray">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_primary"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit PDF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/page_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select a PDF to start"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Save"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:enabled="false"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_save"
                app:iconTint="@color/primary_blue"
                app:iconPadding="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tool bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="@color/background_card">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_pdf"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Open PDF"
            android:textSize="13sp"
            app:icon="@drawable/ic_pdf"
            app:iconPadding="4dp"
            app:cornerRadius="8dp"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Text tool toggle -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tool_text"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Add Text"
            android:textSize="13sp"
            android:enabled="false"
            app:backgroundTint="#EEF2FF"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:icon="@drawable/ic_draw"
            app:iconTint="@color/primary_blue"
            app:iconPadding="4dp"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <!-- Text tool mode banner -->
    <LinearLayout
        android:id="@+id/text_mode_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="#EEF2FF"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_draw"
            app:tint="@color/primary_blue"
            android:contentDescription="Text mode" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Text mode: tap anywhere on a page to add text"
            android:textSize="12sp"
            android:textColor="@color/primary_blue" />

        <TextView
            android:id="@+id/btn_exit_text_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:indeterminateTint="@color/primary_blue"
        android:visibility="gone" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="88dp"
            android:layout_height="88dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#EEF2FF"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_pdf"
                app:tint="@color/primary_blue"
                android:contentDescription="No document" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="No PDF Opened"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Open a PDF to add text, highlights, and more"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- PDF pages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pages_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:visibility="gone" />

</LinearLayout>
