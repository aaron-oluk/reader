<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light_gray">

    <!-- Header — white with bottom shadow -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_white"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="48dp"
            android:paddingBottom="14dp"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit &amp; Sign PDF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/page_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open a PDF to get started"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/loading_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/primary_blue"
            android:visibility="gone" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="#EEF2FF"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_pdf"
                    app:tint="@color/primary_blue"
                    android:contentDescription="No document" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="No PDF Opened"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Tap Open in the toolbar below to choose a PDF"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/pages_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clipToPadding="false"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Active-mode hint bar (replaces tool palette while a tool is active) -->
    <LinearLayout
        android:id="@+id/mode_hint_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_white"
        android:elevation="12dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <!-- Instruction row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#EEF2FF"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/mode_hint_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_draw"
                    app:tint="@color/primary_blue"
                    android:contentDescription="Active mode" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/mode_hint_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Tap any page to add"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- Done button — full width, outlined -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_exit_mode"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Done"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:textAllCaps="false"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary_blue"
            app:strokeWidth="1.5dp"
            app:cornerRadius="14dp" />

    </LinearLayout>

    <!-- Bottom Tool Palette -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tool_palette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="12dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="@color/background_white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tools row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="14dp"
                android:paddingBottom="10dp"
                android:paddingHorizontal="8dp">

                <!-- Open tool -->
                <LinearLayout
                    android:id="@+id/tool_open_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#EEF2FF">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_pdf"
                            android:padding="12dp"
                            android:scaleType="centerInside"
                            app:tint="@color/primary_blue"
                            android:contentDescription="Open PDF" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:background="@color/divider" />

                <!-- Text tool -->
                <LinearLayout
                    android:id="@+id/tool_text_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tool_text_icon_bg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#EEF2FF">

                        <ImageView
                            android:id="@+id/tool_text_icon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_draw"
                            android:padding="12dp"
                            android:scaleType="centerInside"
                            app:tint="@color/primary_blue"
                            android:contentDescription="Add Text" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tool_text_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Text"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:background="@color/divider" />

                <!-- Sign tool -->
                <LinearLayout
                    android:id="@+id/tool_sign_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tool_sign_icon_bg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#EEF2FF">

                        <ImageView
                            android:id="@+id/tool_sign_icon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_signature"
                            android:padding="12dp"
                            android:scaleType="centerInside"
                            app:tint="@color/primary_blue"
                            android:contentDescription="Add Signature" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tool_sign_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Divider above Save -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/divider" />

            <!-- Save PDF button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"
                android:text="Save PDF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:enabled="false"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_save"
                app:iconTint="#FFFFFF"
                app:iconPadding="8dp"
                app:iconGravity="textStart" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
