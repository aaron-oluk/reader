<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/background_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Signature preview thumbnail -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/background_light_gray"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider">
            <ImageView
                android:id="@+id/signature_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:contentDescription="Signature preview" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Name -->
        <TextView
            android:id="@+id/signature_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Signature"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Delete -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_close"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:backgroundTint="#FFF1F1"
            app:iconTint="@color/accent_red"
            app:cornerRadius="10dp"
            android:contentDescription="Delete" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
